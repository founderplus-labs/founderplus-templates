# Founder+ API base — leave as-is unless pointing at a staging env.
FOUNDERPLUS_API_BASE="https://academy.founderplus.id/api/dev"

# REQUIRED: the product slug this app gates on.
# Create the product first:  fp products create --title "..." --price ... --status draft --delivery "..."
# Then copy its slug here (fp products list shows it).
FOUNDERPLUS_PRODUCT_SLUG=""

# OPTIONAL: funnel-tracker.js project id for analytics attribution.
FOUNDERPLUS_PROJECT_ID=""

# Local dev only. NEVER "true" in production — it is ignored when
# NODE_ENV=production, but keep it false to be safe.
AUTH_DEV_BYPASS="false"
